[Unit]
Description=Vietnam Stock Pipeline (Docker Compose Stack)
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/u01/Vanh_projects/vietnam-stock-pipeline
ExecStart=/usr/bin/docker compose -f /u01/Vanh_projects/vietnam-stock-pipeline/docker-compose-timescaledb.yml up -d
ExecStop=/usr/bin/docker compose -f /u01/Vanh_projects/vietnam-stock-pipeline/docker-compose-timescaledb.yml down
ExecReload=/usr/bin/docker compose -f /u01/Vanh_projects/vietnam-stock-pipeline/docker-compose-timescaledb.yml up -d --build dashboard
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
